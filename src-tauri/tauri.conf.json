{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Scholar Translate",
  "version": "0.3.1",
  "identifier": "com.scholar-translate.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && node scripts/build-python.cjs",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Scholar Translate",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:5173 http://localhost:18088 http://localhost:11434 http://127.0.0.1:18088; connect-src *; style-src * 'unsafe-inline'; font-src * data:; img-src * asset: https://asset.localhost data: blob:; media-src * asset: https://asset.localhost blob:",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$HOME/**", "$PICTURE/**", "$VIDEO/**", "$DOWNLOAD/**", "$DESKTOP/**", "$DOCUMENT/**"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "resources": [
      "WebView2Loader.dll",
      "python-dist"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"]
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
